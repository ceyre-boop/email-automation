# ── Google OAuth (one app, all talents authenticate through it) ──────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret_here
# The exact URI you registered in Google Cloud Console
GOOGLE_REDIRECT_URI=https://yourapp.com/auth/callback

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# From Supabase → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── Google Sheets auth ─────────────────────────────────────────────────────────
# Preferred: OAuth refresh token generated once with:
#   python scripts/generate_google_refresh_token.py
# This is the path that works reliably when service-account JSON is blocked.
GOOGLE_SHEETS_REFRESH_TOKEN=your_google_sheets_refresh_token_here
#
# Optional legacy fallback: service account credentials.
# Leave these blank unless you intentionally want the service-account flow.
# Option A: inline JSON (useful for env vars)
# GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B: local file path (useful for local dev)
# GOOGLE_SHEETS_SERVICE_ACCOUNT_FILE=secrets/service_account.json

# ── App ───────────────────────────────────────────────────────────────────────
APP_BASE_URL=https://yourapp.com
# Secret used to sign internal JWT tokens for the agency dashboard
AGENCY_SECRET_KEY=change_me_to_a_long_random_string
# API key required in the x-api-key header for protected endpoints (/api/drafts, /api/status)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=change_me_to_a_long_random_string
# Comma-separated list of allowed agency dashboard origins (CORS)
ALLOWED_ORIGINS=https://yourapp.com,http://localhost:3000

# ── Polling ───────────────────────────────────────────────────────────────────
# How often the inbox poller runs (minutes). 5 = every 5 minutes.
POLL_INTERVAL_MINUTES=5
